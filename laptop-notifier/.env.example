# Easiest: paste the SAME REDIS_URL the bot uses on Dokploy (Upstash gives a
# rediss://default:PASSWORD@host:6379 URL — note "rediss" = TLS). If set, this
# is used and the discrete REDIS_HOST/PORT/PASSWORD/TLS vars below are ignored.
REDIS_URL=rediss://default:YOUR_PASSWORD@louse-135393.upstash.io:6379

# Only used if REDIS_URL above is left blank:
# REDIS_HOST=louse-135393.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true

# Must match LAPTOP_NOTIFY_CHANNEL on the bot (default already matches).
NOTIFY_CHANNEL=laptop:notify

# Only pop a toast for these severities (comma-separated: low,medium,high).
MIN_SEVERITIES=low,medium,high

# Single-instance lock port (loopback). Only one notifier runs at a time — this
# prevents duplicate toasts and makes the auto-start self-heal safe.
# NOTIFIER_LOCK_PORT=47615

# WhatsApp presence: reports "online" to the bot ONLY while WhatsApp is the
# focused window — so being at the computer in another app counts as away and
# you still get notified. Requires the active-win dependency.
WA_PRESENCE=true
PRESENCE_PING_SEC=7      # How often to check the focused window
# WHATSAPP_MATCH=whatsapp  # OPTIONAL override regex. Leave commented to use smart
#                          # detection (WhatsApp app, or a browser tab actually on
#                          # WhatsApp Web) that ignores windows merely mentioning
#                          # "whatsapp" (this repo, editors, terminals).
