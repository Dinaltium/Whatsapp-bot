GROQ_API_KEY=replace_me
GROQ_MODEL=llama-3.3-70b-versatile
ALLOW_FROM_ME_MESSAGES=true

ADMIN_JIDS=1234567890@s.whatsapp.net
ALLOWED_GROUPS_FILE=allowed-groups.json
ALLOWED_CHATS_FILE=allowed-chats.json
USER_DAILY_ASSISTANT_LIMIT=50
MAX_MESSAGE_QUEUE_DEPTH=200

# Neon PostgreSQL (optional but recommended for cloud persistence)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Optional: JWT-wrap auth state stored in DB
AUTH_STATE_JWT_SECRET=replace_with_long_random_secret
