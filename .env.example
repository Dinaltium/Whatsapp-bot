# -- Core ------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
ADMIN_JIDS=919902849280@s.whatsapp.net
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
REDIS_URL=redis://...

# -- Optional Core ---------------------------------------------------------
GROQ_MODEL_SCOUT=meta-llama/llama-4-scout-17b-16e-instruct
ALLOWED_GROUPS=1203630234567@g.us 1
ALLOWED_CHATS=919902849280@s.whatsapp.net 2
AUTH_STATE_KEY=your_auth_state_encryption_key   # REQUIRED: encrypts WhatsApp session creds at rest
AUTH_STATE_JWT_SECRET=your_secret_here          # Fallback key if AUTH_STATE_KEY unset
# ALLOW_UNENCRYPTED_AUTH_STATE=true             # Opt out of the encryption requirement (NOT recommended)
ALLOW_FROM_ME_MESSAGES=false
OUTGOING_GLOBAL_PER_MIN=15      # Max bot messages/min across ALL recipients (account-level ban guard)
# DEDUP_VARY_BROADCAST=true     # Vary identical repeated replies with an invisible char (default off; hidden chars can also read as spam)
PORT=3000
LOG_LEVEL=info
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_SSL_REJECT_UNAUTHORIZED=true   # Set false for Supabase/Neon poolers (their CA isn't in Node's trust store → "self-signed certificate in certificate chain")

# -- SELF Bot --------------------------------------------------------------
TAVILY_API_KEY=tvly-...        # Web search -- https://tavily.com (free: 1000/month)
FIRECRAWL_API_KEY=fc-...       # Web extract -- https://firecrawl.dev (optional, Tavily fallback)
SEARCH_CACHE_TTL_SEC=21600     # Cache non-live web-search results (default 6h); recency queries never cached
SELF_BOT_ENABLED=true          # Set false to disable !! prefix entirely

# -- Agentic RAG search providers ------------------------------------------
# The SELF bot fans out across every configured engine in PARALLEL, fuses the
# rankings, reads the top page's full text, then answers grounded + cited (or
# abstains). Set as many as you like — more engines = better coverage. With
# none set, the bot answers from model knowledge only.
# EXA_API_KEY=...              # Neural search -- https://exa.ai (great for niche/technical recall)
#   TAVILY_API_KEY / FIRECRAWL_API_KEY (above) also feed the fan-out.
#   Deep page-reads use Firecrawl when set, else the keyless Jina Reader (r.jina.ai).

# -- Google Calendar (optional, for !!gcal) --------------------------------
# Point to the service-account key file (easiest) OR paste the JSON inline.
# Then share your calendar with the service account's email ("Make changes to
# events") and set GOOGLE_CALENDAR_ID to that calendar.
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/gcal-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}
# GOOGLE_CALENDAR_ID=you@gmail.com
# GOOGLE_CALENDAR_TZ=Asia/Kolkata

# -- Intro notifier --------------------------------------------------------
# When someone is added to a DKB (bot 2) group, the bot posts an !addmentor
# prompt to the mentor group. Prefer setting this at runtime with
# `!notify -id <groupId>` (durable, no redeploy); this env var is only a
# fallback. Leave both unset to disable member-join notices.
# INTRO_NOTIFY_GROUP_JID=1203630000000@g.us

# -- ECB (future) ----------------------------------------------------------
# No additional env vars needed yet
